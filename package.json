{
  "name": "@davidsneighbour/unsplash-download-tracker",
  "description": "Synchronise a user's personal Unsplash download history into a local archive.",
  "version": "0.0.1",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidsneighbour/jaq-unsplash-download-tracker.git"
  },
  "author": "Patrick Kollitsch <davidsneighbourdev+gh@gmail.com>",
  "bugs": {
    "url": "https://github.com/davidsneighbour/jaq-unsplash-download-tracker/issues"
  },
  "homepage": "https://github.com/davidsneighbour/jaq-unsplash-download-tracker#readme",
  "keywords": [],
  "dependencies": {
    "playwright": "1.59.1"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "10.0.6",
    "@types/node": "25.5.2",
    "release-it": "19.2.4"
  },
  "scripts": {
    "release": "release-it",
    "release:ci": "release-it --ci",
    "sync": "node index.ts --verbose"
  },
  "main": "index.ts",
  "engines": {
    "node": ">=22"
  },
  "cspell": {
    "language": "en-GB",
    "dictionaryDefinitions": [
      {
        "name": "local-project-words",
        "path": "./.github/custom-dictionary.txt",
        "addWords": true
      }
    ],
    "dictionaries": [
      "local-project-words"
    ]
  },
  "type": "module"
}
